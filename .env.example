# Project Aura — Environment Variables Template
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.
# Backend secrets must NEVER appear in frontend code or Netlify build env.

# ---------------------------------------------------------------------------
# Modal (backend deployment runtime)
# ---------------------------------------------------------------------------
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ---------------------------------------------------------------------------
# STT provider — Deepgram (Phase 12A)
# STT_API_KEY is the canonical name. The adapter also accepts DEEPGRAM_API_KEY
# as a backward-compat alias, but set only STT_API_KEY here and in Modal Secret.
# ---------------------------------------------------------------------------
STT_PROVIDER=deepgram
STT_API_KEY=

# ---------------------------------------------------------------------------
# LLM provider
# STUB: provider not yet selected (Anthropic and OpenAI are candidates)
# ---------------------------------------------------------------------------
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=

# ---------------------------------------------------------------------------
# TTS / voice provider
# STUB: provider not yet selected (ElevenLabs and Cartesia are candidates)
# ---------------------------------------------------------------------------
TTS_PROVIDER=stub
TTS_API_KEY=
TTS_VOICE_ID=

# ---------------------------------------------------------------------------
# Redis (session state store)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Persistent memory store
# STUB: backend not yet selected (Supabase, Postgres, SQLite are candidates)
# ---------------------------------------------------------------------------
MEMORY_STORE_URL=
MEMORY_STORE_KEY=

# ---------------------------------------------------------------------------
# Session security
# ---------------------------------------------------------------------------
SESSION_SECRET_KEY=changeme-replace-this

# ---------------------------------------------------------------------------
# Adult mode
# Set to "true" ONLY for approved private testers.
# False by default — do not enable carelessly.
# ---------------------------------------------------------------------------
ADULT_MODE_ENABLED=false

# ---------------------------------------------------------------------------
# Memory data directory
# Local: leave unset — defaults to data/memory/ relative to project root.
# Modal: set to /data/memory (the Modal Volume mount path).
#        This is handled automatically by modal_app.py; no manual change needed.
# ---------------------------------------------------------------------------
DATA_DIR=

# ---------------------------------------------------------------------------
# Demo / investor access (Phase 12)
# DEMO_TOKEN: secret string required in POST /session/create to enter the
# adult demo lane. Share only via a private URL (?demo=<token>).
# Leave unset to disable demo access entirely.
# ---------------------------------------------------------------------------
DEMO_TOKEN=

# Relationship closeness the demo session opens at (1=New … 4=Intimate).
# Default 4 so all NSFW gates pass immediately. Lower to start warmer but
# not fully explicit (e.g. DEMO_STARTING_CLOSENESS=3 = Close/Affectionate).
DEMO_STARTING_CLOSENESS=4

# Separate LLM config for the adult demo lane.
# If LLM_DEMO_MODEL is unset, demo sessions fall back to the standard adapter.
# LLM_DEMO_API_KEY defaults to ANTHROPIC_API_KEY if not set separately.
# LLM_DEMO_BASE_URL defaults to ANTHROPIC_BASE_URL if not set separately.
LLM_DEMO_MODEL=
LLM_DEMO_BASE_URL=
LLM_DEMO_API_KEY=
LLM_DEMO_MAX_TOKENS=300

# ---------------------------------------------------------------------------
# CORS allowed origins (backend)
# Comma-separated list of origins permitted to call the session API.
# Defaults to common local dev ports if not set.
# For Modal/Netlify: add your Netlify URL, e.g.:
#   CORS_ORIGINS=https://your-app.netlify.app
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ===========================================================================
# Phase 12A — Voice stack (investor demo lane)
# ===========================================================================

# ---------------------------------------------------------------------------
# Daily WebRTC transport
# Required to enable voice sessions. Leave unset for text-only mode.
# Get your API key at https://dashboard.daily.co
# ---------------------------------------------------------------------------
DAILY_API_KEY=
# How long created rooms live before Daily auto-expires them (seconds).
# Default 3600 (1 hour). Lower for tighter cleanup, higher for long demos.
DAILY_ROOM_EXPIRY_SECONDS=3600

# ---------------------------------------------------------------------------
# vLLM — Dolphin-Mistral-24B-Venice-Edition on Modal
# VLLM_BASE_URL: the /v1 endpoint of your deployed modal_vllm.py service.
# Example: https://your-org--aura-vllm-serve.modal.run/v1
# When set, demo sessions use OpenAICompatibleDialogueAdapter instead of
# falling back to Anthropic.
# VLLM_MODEL must match the --model argument passed to the vLLM server.
# ---------------------------------------------------------------------------
VLLM_BASE_URL=
VLLM_API_KEY=no-key-required
VLLM_MODEL=cognitivecomputations/Dolphin3.0-Mistral-24B
VLLM_MAX_TOKENS=300

# ---------------------------------------------------------------------------
# Fish Audio S2 Pro — self-hosted on Modal
# FISH_AUDIO_URL: the base URL of your deployed modal_fish.py service.
# Example: https://your-org--aura-fish-serve.modal.run
# FISH_AUDIO_VOICE_ID: the reference_id (voice model) to use for synthesis.
# Leave FISH_AUDIO_API_KEY empty if your Modal service has no auth middleware.
# ---------------------------------------------------------------------------
FISH_AUDIO_URL=
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# (STT_API_KEY and STT_PROVIDER are defined once at the top of this file.)
